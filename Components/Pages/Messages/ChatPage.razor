@page "/chat"
@page "/chat/{ThreadId}"
@using CMetalsWS.Services

<MudPaper Class="d-flex pa-3 gap-3" Elevation="0" Style="min-height:calc(100vh - 128px)">
  <MudItem xs="12" md="4" lg="3"><ChatThreadPanel /></MudItem>
  <MudItem xs="12" md="8" lg="9">
    @if (!string.IsNullOrEmpty(ThreadId))
    {
        <ChatConversation ThreadId="@ThreadId" />
    }
    else
    {
        <MudPaper Class="d-flex align-center justify-center" Style="height:70vh;">
            <MudText Typo="Typo.h6" Class="mud-text-secondary">Select a conversation from the left.</MudText>
        </MudPaper>
    }
  </MudItem>
</MudPaper>

@code {
    [Parameter]
    public string? ThreadId { get; set; }
}
